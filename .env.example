# Copy this file to .env and adjust if needed.
# The defaults below give a fully local, zero-API-key deployment.

# ---------------------------------------------------------------------------
# Embedding — determines the vector space. Pick ONCE; changing it later
# requires re-embedding (the service refuses to start on a mismatch).
#   fastembed (default: local, no key, baked into the image) | ollama | openai | nvidia
# ---------------------------------------------------------------------------
EMBED_PROVIDER=fastembed
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---------------------------------------------------------------------------
# LLM — optional, safe to switch anytime. Used for auto-consolidation and
# /chat. With "none", auto-consolidation is disabled and Hermes' own model
# handles it via the `consolidate_session` MCP tool.
# setup.sh borrows an existing key from ~/.hermes/.env (NVIDIA -> Gemini)
# when LLM_PROVIDER is still none.
#   none (default) | anthropic | openai | nvidia | gemini | ollama
# ---------------------------------------------------------------------------
LLM_PROVIDER=none
#LLM_MODEL=claude-sonnet-5
#ANTHROPIC_API_KEY=sk-ant-...
#OPENAI_API_KEY=sk-...
#NVIDIA_API_KEY=nvapi-...
#GOOGLE_API_KEY=AIza...

# Auto-consolidation (requires an LLM) — event-driven: distills when a session
# ends (on_session_end), catch-up sweep when Desktop opens (on_session_start,
# 10-min debounce), and once at service startup. Set CONSOLIDATION_INTERVAL > 0
# (seconds) to add a periodic loop as well.
#CONSOLIDATION_ENABLED=true
#CONSOLIDATION_INTERVAL=0
#CONSOLIDATION_SWEEP_DEBOUNCE=600
#CONSOLIDATION_IDLE_SECONDS=900
#CONSOLIDATION_MIN_TURNS=2
#CONSOLIDATION_MAX_FACTS=5
#CONSOLIDATION_MIN_IMPORTANCE=0.5

# For LLM_PROVIDER=ollama: use the host Ollama (default) or the optional
# containerized one (docker compose --profile ollama up -d):
#OLLAMA_BASE_URL=http://ollama:11434

# ---------------------------------------------------------------------------
# Identity & collections (defaults are fine for single-user)
# ---------------------------------------------------------------------------
# (HERMES_USER_ID, the pre-rename name, is still honored as a legacy alias)
LONGBRAIN_USER_ID=local
DOCUMENTS_COLLECTION=longbrain_documents
CHAT_HISTORY_COLLECTION=longbrain_chat_history
MEMORIES_COLLECTION=longbrain_memories

# Max tokens kept in the rolling chat memory window per session
CHAT_MEMORY_TOKEN_LIMIT=3000

# ---------------------------------------------------------------------------
# Recall tuning (defaults mirror app/config.py; thresholds are calibrated to
# the default MiniLM embedding — retune them if you ever switch models)
# ---------------------------------------------------------------------------
# Results scoring below this are dropped entirely (nothing relevant -> nothing injected)
#RECALL_MIN_SCORE=0.25
# How many hits each channel contributes to the context block
#RECALL_TOP_K_MEMORIES=5
#RECALL_TOP_K_HISTORY=3
#RECALL_TOP_K_DOCS=2
#RECALL_RECENT_TURNS=6
# Max chars per injected document snippet
#RECALL_DOC_SNIPPET_CHARS=600
# Rerank multipliers: same-project hits / type=preference hits
#RECALL_PROJECT_BOOST=1.5
#RECALL_PREFERENCE_BOOST=1.5
# Recency decay half-lives (days) for facts / raw chat history
#MEMORY_HALF_LIFE_DAYS=90
#HISTORY_HALF_LIFE_DAYS=30
# Similarity >= this: a new fact silently supersedes the old near-duplicate;
# between DEDUP_LLM_CHECK_MIN and that: an LLM (when configured) judges
# "same fact reworded?" before superseding
#SUPERSEDE_SIMILARITY=0.92
#DEDUP_LLM_CHECK_MIN=0.60

# ---------------------------------------------------------------------------
# Hybrid recall — BM25 keyword rescue for identifier-like tokens (10MB,
# ERR_..., snake_case, quoted strings). Only ever ADDS exact matches the
# dense model under-ranks; ordinary prompts are unaffected. Collections
# created before this feature need scripts/migrate_hybrid_bm25.py once.
# ---------------------------------------------------------------------------
#HYBRID_BM25=true
#RECALL_BM25_WEIGHT=0.6
