# Copy this file to .env and adjust if needed.
# The defaults below give a fully local, zero-API-key deployment.

# ---------------------------------------------------------------------------
# Embedding — determines the vector space. Pick ONCE; changing it later
# requires re-embedding (the service refuses to start on a mismatch).
#   fastembed (default: local, no key, baked into the image) | ollama | openai | nvidia
# ---------------------------------------------------------------------------
EMBED_PROVIDER=fastembed
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---------------------------------------------------------------------------
# LLM — optional, safe to switch anytime. Used for auto-consolidation and
# /chat. With "none", auto-consolidation is disabled and Hermes' own model
# handles it via the `consolidate_session` MCP tool.
# setup.sh tự mượn key có sẵn trong ~/.hermes/.env (NVIDIA -> Gemini) nếu
# LLM_PROVIDER đang là none.
#   none (default) | anthropic | openai | nvidia | gemini | ollama
# ---------------------------------------------------------------------------
LLM_PROVIDER=none
#LLM_MODEL=claude-sonnet-5
#ANTHROPIC_API_KEY=sk-ant-...
#OPENAI_API_KEY=sk-...
#NVIDIA_API_KEY=nvapi-...
#GOOGLE_API_KEY=AIza...

# Auto-consolidation (cần LLM) — event-driven: chưng cất khi phiên kết thúc
# (on_session_end), quét bù khi mở Desktop (on_session_start, debounce 10ph)
# và một lần lúc service khởi động. Đặt CONSOLIDATION_INTERVAL > 0 (giây)
# nếu muốn thêm vòng lặp định kỳ.
#CONSOLIDATION_ENABLED=true
#CONSOLIDATION_INTERVAL=0
#CONSOLIDATION_SWEEP_DEBOUNCE=600
#CONSOLIDATION_IDLE_SECONDS=900
#CONSOLIDATION_MIN_TURNS=2
#CONSOLIDATION_MAX_FACTS=5
#CONSOLIDATION_MIN_IMPORTANCE=0.5

# For LLM_PROVIDER=ollama: use the host Ollama (default) or the optional
# containerized one (docker compose --profile ollama up -d):
#OLLAMA_BASE_URL=http://ollama:11434

# ---------------------------------------------------------------------------
# Identity & collections (defaults are fine for single-user)
# ---------------------------------------------------------------------------
HERMES_USER_ID=local
DOCUMENTS_COLLECTION=hermes_documents
CHAT_HISTORY_COLLECTION=hermes_chat_history
MEMORIES_COLLECTION=hermes_memories

# Max tokens kept in the rolling chat memory window per session
CHAT_MEMORY_TOKEN_LIMIT=3000
